{
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:native": "turbo run dev --filter=native",
    "android": "turbo run android --filter=native",
    "android:build": "turbo run android:build --filter=native",
    "ios": "turbo run ios --filter=native",
    "native:web": "turbo run web --filter=native",
    "doctor": "turbo run doctor --filter=native",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "check": "turbo run lint typecheck format:check format:check:root",
    "ci": "turbo run lint typecheck build format:check format:check:root",
    "setup": "turbo run codegen:program",
    "anchor:build": "turbo run anchor:build --filter=@repo/anchor-program",
    "anchor:test": "turbo run anchor:test --filter=@repo/anchor-program",
    "codama:js": "turbo run codegen:program",
    "codegen:program": "codama run js",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "turbo run format format:root --continue",
    "format:root": "prettier --write \"*.{json,md,yml,yaml}\" \"programs/anchor/*.md\" --ignore-path .prettierignore",
    "format:check": "turbo run format:check format:check:root --continue",
    "format:check:root": "prettier --check \"*.{json,md,yml,yaml}\" \"programs/anchor/*.md\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.3.8",
    "@codama/renderers-js": "^1.5.5",
    "codama": "^1.5.0",
    "prettier": "^3.1.1",
    "turbo": "^2.9.9"
  },
  "engines": {
    "node": ">=18"
  },
  "name": "harvverse-miami-tracks",
  "packageManager": "pnpm@10.17.1",
  "pnpm": {
    "overrides": {
      "@wallet-ui/react-native-kit>@solana-program/memo": "^0.11.0"
    }
  }
}
