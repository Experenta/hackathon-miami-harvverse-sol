{
  "name": "@repo/anchor-program",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "anchor:build": "PATH=\"$HOME/.local/share/solana/install/active_release/bin:$HOME/.cargo/bin:$HOME/.avm/bin:$PATH\" anchor build",
    "anchor:deploy:local": "PATH=\"$HOME/.local/share/solana/install/active_release/bin:$HOME/.cargo/bin:$HOME/.avm/bin:$PATH\" anchor deploy --provider.cluster localnet",
    "anchor:test": "PATH=\"$HOME/.local/share/solana/install/active_release/bin:$HOME/.cargo/bin:$HOME/.avm/bin:$PATH\" anchor test --skip-deploy",
    "test": "ts-mocha -p ./tsconfig.json -t 1000000 'tests/**/*.ts'",
    "clean": "rm -rf target .anchor"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.95.0",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.6",
    "chai": "^4.4.1",
    "mocha": "^10.2.0",
    "ts-mocha": "^10.0.0",
    "typescript": "5.9.2"
  }
}
