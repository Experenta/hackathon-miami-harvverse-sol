{
  "name": "@repo/solana-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./generated/harvverse": "./src/generated/harvverse/index.ts",
    "./harvverse": "./src/harvverse/index.ts"
  },
  "scripts": {
    "build": "pnpm run typecheck",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@solana/kit": "^6.3.0",
    "@solana/kit-plugin-rpc": "^0.7.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.10.6",
    "typescript": "5.9.2"
  }
}
