{
  "name": "@havverse/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./convex/_generated/api.js",
  "types": "./convex/_generated/api.d.ts",
  "exports": {
    ".": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./convex/_generated/api": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./convex/_generated/dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    },
    "./convex/_generated/server": {
      "types": "./convex/_generated/server.d.ts",
      "default": "./convex/_generated/server.js"
    }
  },
  "scripts": {
    "build": "pnpm run typecheck",
    "clean": "rm -rf .convex",
    "codegen": "convex codegen",
    "dev": "convex dev",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "setup": "convex dev --until-success",
    "typecheck": "tsc --noEmit -p convex"
  },
  "dependencies": {
    "convex": "^1.37.0"
  },
  "devDependencies": {
    "typescript": "5.9.2"
  }
}
